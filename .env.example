# Address Book IDs
DOTDIGITAL_ADDRESSBOOK_NEWSLETTER=
DOTDIGITAL_ADDRESSBOOK_BUYERS=
DOTDIGITAL_ADDRESSBOOK_AGENTS=
DOTDIGITAL_ADDRESSBOOK_SUPPLIERS=

# Campaign IDs (Triggered campaigns)
