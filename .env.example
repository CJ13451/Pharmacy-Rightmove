DOTDIGITAL_CAMPAIGN_EMAIL_VERIFICATION=
DOTDIGITAL_CAMPAIGN_PASSWORD_RESET=
DOTDIGITAL_CAMPAIGN_NEW_LISTING_ALERT=
DOTDIGITAL_CAMPAIGN_ENQUIRY_RECEIVED=
DOTDIGITAL_CAMPAIGN_ENQUIRY_CONFIRMATION=
DOTDIGITAL_CAMPAIGN_COURSE_PURCHASE=
DOTDIGITAL_CAMPAIGN_COURSE_COMPLETION=
DOTDIGITAL_CAMPAIGN_LISTING_PUBLISHED=
DOTDIGITAL_CAMPAIGN_LISTING_EXPIRING=
DOTDIGITAL_CAMPAIGN_SUBSCRIPTION_WELCOME=
DOTDIGITAL_CAMPAIGN_SUBSCRIPTION_RENEWAL=
DOTDIGITAL_CAMPAIGN_SUBSCRIPTION_CANCELLED=
