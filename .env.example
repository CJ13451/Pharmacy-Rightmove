APP_NAME="Pharmacy Owner by P3"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/London
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_GB

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=p3_pharmacy
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@pharmacyowner.co.uk"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-2
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# STRIPE CONFIGURATION
# =============================================================================
STRIPE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Listing prices (in pence)
STRIPE_LISTING_STANDARD_PRICE=29900
STRIPE_LISTING_FEATURED_PRICE=49900
STRIPE_LISTING_PREMIUM_PRICE=79900

# Supplier subscription Price IDs (create in Stripe Dashboard)
STRIPE_SUPPLIER_PREMIUM_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_SUPPLIER_PREMIUM_YEARLY=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_SUPPLIER_FEATURED_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_SUPPLIER_FEATURED_YEARLY=price_xxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# DOTDIGITAL CONFIGURATION
# =============================================================================
DOTDIGITAL_BASE_URL=https://r1-api.dotdigital.com
DOTDIGITAL_USERNAME=apiuser-xxxxxxxxx@apiconnector.com
